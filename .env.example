# ============================================================
# Environment Configuration
# Copy this to .env and fill in values for your environment
# ============================================================

# Databricks Connection (production data access)
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-token-here
DATABRICKS_CLUSTER_ID=your-cluster-id

# Azure Storage (for raw data backup)
AZURE_STORAGE_ACCOUNT=retaildatalake
AZURE_STORAGE_KEY=your-key-here

# Pipeline Configuration
ENVIRONMENT=development       # development | staging | production
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
CAMPAIGN_ID=PROMO-2025-Q4-HOLIDAY

# Slack Alerts (pipeline monitoring)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
ALERT_ON_FAILURE=true
ALERT_ON_SUCCESS=false
